# OpenAI — used for ChatGPT queries
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Google AI Studio — used for Gemini queries
GOOGLE_API_KEY=AIza...
GEMINI_MODEL=gemini-1.5-flash

# Anthropic — used for content generation (blog post, social posts)
ANTHROPIC_API_KEY=sk-ant-...

# Database path (defaults to citation_index.db in project root)
# DATABASE_URL=sqlite:///citation_index.db

# Perplexity runs via Puter.js in the browser — no API key required
